# =========================================================================
# Gyan Azure VM Manager - Environment Configuration Template
# Copy this file to '.env' and fill in the values before running the app.
# =========================================================================

# --- REQUIRED Cryptographic Keys ---
# 1. JWT_SECRET: Secret key used to sign JSON Web Tokens.
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=replace_with_a_secure_random_hex_string_32_characters

# 2. FERNET_KEY: 32-byte URL-safe base64-encoded key for credential encryption.
# Generate this key using Python:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_with_a_32_byte_url_safe_base64_encoded_key


# --- SEED Administrator Account ---
# Created on first startup. Forces password change is recommended.
ADMIN_EMAIL=admin@gyan.ai
ADMIN_PASSWORD=GyanAdminPassword123!
